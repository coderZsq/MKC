{
  "title": "MKC System Overview",
  "uid": "mkc-overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "QPS",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(mkc_gateway_http_requests_total[5m])) + sum(rate(mkc_ai_http_requests_total[5m]))",
          "legendFormat": "requests/s"
        }
      ]
    },
    {
      "id": 2,
      "title": "P95 Latency",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(mkc_gateway_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "gateway p95"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(mkc_ai_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "ai p95"
        }
      ]
    },
    {
      "id": 3,
      "title": "P99 Latency",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(mkc_gateway_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "gateway p99"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(mkc_ai_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "ai p99"
        }
      ]
    },
    {
      "id": 4,
      "title": "5xx Error Rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(mkc_gateway_http_errors_total[5m])) / clamp_min(sum(rate(mkc_gateway_http_requests_total[5m])), 1)",
          "legendFormat": "gateway 5xx"
        },
        {
          "expr": "sum(rate(mkc_ai_http_errors_total[5m])) / clamp_min(sum(rate(mkc_ai_http_requests_total[5m])), 1)",
          "legendFormat": "ai 5xx"
        }
      ]
    }
  ]
}

