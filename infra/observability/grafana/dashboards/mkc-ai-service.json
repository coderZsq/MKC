{
  "title": "MKC AI Service",
  "uid": "mkc-ai-service",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "LLM Requests",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(mkc_ai_llm_requests_total[5m])) by (provider, model, status)",
          "legendFormat": "{{provider}} {{model}} {{status}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "LLM Tokens",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(mkc_ai_llm_tokens_total[5m])) by (provider, model, token_type)",
          "legendFormat": "{{provider}} {{model}} {{token_type}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "LLM Failure Rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(mkc_ai_llm_requests_total{status=\"error\"}[5m])) / clamp_min(sum(rate(mkc_ai_llm_requests_total[5m])), 1)",
          "legendFormat": "failure rate"
        }
      ]
    },
    {
      "id": 4,
      "title": "Retrieval Requests",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(mkc_ai_retrieval_requests_total[5m])) by (operation, status)",
          "legendFormat": "{{operation}} {{status}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Task Queue Duration",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(mkc_ai_task_duration_seconds_bucket[5m])) by (le, task_type, status))",
          "legendFormat": "{{task_type}} {{status}} p95"
        }
      ]
    }
  ]
}

