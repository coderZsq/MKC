APP_NAME=mkc-ai-service
DEBUG=True
ENV=dev
PORT=5000
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/1
INTERNAL_API_KEY=change-me
LOG_LEVEL=INFO

# Embedding provider: ollama / zhipuai / openai / mock
# Local development defaults to local Ollama bge-m3 (1024-dim, no API key).
# Pull the model first: `ollama pull bge-m3`
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=bge-m3
EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_DIMENSIONS=1024
# Vector store collection dimension MUST match EMBEDDING_DIMENSIONS.
# Changing the embedding model/dimension requires dropping and recreating the
# vector collection, then re-embedding existing resources.
VECTOR_STORE_DIMENSIONS=1024

# Optional: API keys for remote embedding/LLM providers (zhipuai / openai / kimi)
# or text_cleaning llm/hybrid mode. Not needed for local Ollama.
# ZHIPU_API_KEY=change-me
# OPENAI_API_KEY=change-me
# KIMI_API_KEY=change-me
# EMBEDDING_PROVIDER=zhipuai
