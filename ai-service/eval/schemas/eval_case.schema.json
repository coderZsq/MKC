{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mkc.local/schemas/eval_case.schema.json",
  "title": "MKC RAG Evaluation Case",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "question",
    "expected_answer",
    "resource_ids",
    "expected_citations",
    "tags",
    "difficulty"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^rag-[a-z0-9-]+-[0-9]{3}$"
    },
    "question": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "expected_answer": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1200
    },
    "resource_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "expected_citations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/expectedCitation"
      }
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "difficulty": {
      "type": "string",
      "enum": ["easy", "medium", "hard"]
    }
  },
  "$defs": {
    "expectedCitation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["resource_id"],
      "properties": {
        "resource_id": {
          "type": "string",
          "minLength": 1
        },
        "chunk_id": {
          "type": "string",
          "minLength": 1
        },
        "page": {
          "type": "integer",
          "minimum": 1
        },
        "start_sec": {
          "type": "number",
          "minimum": 0
        },
        "end_sec": {
          "type": "number",
          "minimum": 0
        },
        "quote_hint": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        }
      },
      "anyOf": [
        {"required": ["chunk_id"]},
        {"required": ["page"]},
        {"required": ["start_sec", "end_sec"]}
      ]
    }
  }
}
